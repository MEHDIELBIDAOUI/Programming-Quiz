<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="24dp"
    android:background="@drawable/bg_rounded_input">

    <TextView
        android:id="@+id/tvPreviewCategory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Java - Moyen"
        android:textColor="@color/textSecondary"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvPreviewQuestion"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Question text..."
        android:textColor="@color/on_background"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvPreviewCategory"
        android:layout_marginTop="16dp"/>

    <LinearLayout
        android:id="@+id/llPreviewOptions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvPreviewQuestion"
        android:layout_marginTop="24dp">

        <TextView
            android:id="@+id/tvPreviewOption1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_rounded_input"
            android:padding="16dp"
            android:text="Option 1"
            android:textColor="@color/on_surface" />

        <TextView
            android:id="@+id/tvPreviewOption2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_rounded_input"
            android:padding="16dp"
            android:text="Option 2"
            android:textColor="@color/on_surface" />

        <TextView
            android:id="@+id/tvPreviewOption3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_rounded_input"
            android:padding="16dp"
            android:text="Option 3"
            android:textColor="@color/on_surface" />

        <TextView
            android:id="@+id/tvPreviewOption4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_rounded_input"
            android:padding="16dp"
            android:text="Option 4"
            android:textColor="@color/on_surface" />
    </LinearLayout>

    <Button
        android:id="@+id/btnPreviewClose"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Fermer"
        android:backgroundTint="@color/primary"
        android:textColor="@color/on_primary"
        app:layout_constraintTop_toBottomOf="@+id/llPreviewOptions"
        android:layout_marginTop="24dp" />

</androidx.constraintlayout.widget.ConstraintLayout>

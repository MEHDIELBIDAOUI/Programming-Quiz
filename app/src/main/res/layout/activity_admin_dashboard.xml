<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="24dp"
    tools:context=".activities.AdminDashboardActivity">

    <TextView
        android:id="@+id/tvAdminTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Panneau Administrateur"
        android:textColor="@color/on_background"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="16dp"/>

    <!-- Stats Section 1 -->
    <LinearLayout
        android:id="@+id/llStats1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@+id/tvAdminTitle">

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_weight="1"
            app:cardBackgroundColor="@color/surface_variant"
            app:cardCornerRadius="16dp"
            android:layout_marginEnd="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Utilisateurs"
                    android:textColor="@color/textSecondary"/>
                <TextView
                    android:id="@+id/tvTotalUsers"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_weight="1"
            app:cardBackgroundColor="@color/surface_variant"
            app:cardCornerRadius="16dp"
            android:layout_marginStart="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Top Score"
                    android:textColor="@color/textSecondary"/>
                <TextView
                    android:id="@+id/tvTopScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#FFD700"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- Stats Section 2 -->
    <LinearLayout
        android:id="@+id/llStats2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@+id/llStats1">

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_weight="1"
            app:cardBackgroundColor="@color/surface_variant"
            app:cardCornerRadius="16dp"
            android:layout_marginEnd="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Questions"
                    android:textColor="@color/textSecondary"/>
                <TextView
                    android:id="@+id/tvTotalQuestions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/secondary"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_weight="1"
            app:cardBackgroundColor="@color/surface_variant"
            app:cardCornerRadius="16dp"
            android:layout_marginStart="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Code Challenges"
                    android:textColor="@color/textSecondary"/>
                <TextView
                    android:id="@+id/tvTotalCodeChallenges"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/error"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <Button
        android:id="@+id/btnAddQuestion"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="➕ Add Question"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="@color/primary"
        android:textColor="@color/on_primary"
        app:cornerRadius="16dp"
        app:layout_constraintTop_toBottomOf="@+id/llStats2"
        android:layout_marginTop="32dp"/>

    <Button
        android:id="@+id/btnAddCodeChallenge"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="➕ Add Code Challenge"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#FF9800"
        android:textColor="#FFFFFF"
        app:cornerRadius="16dp"
        app:layout_constraintTop_toBottomOf="@+id/btnAddQuestion"
        android:layout_marginTop="16dp"/>

    <Button
        android:id="@+id/btnManageQuestions"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="📚 Manage Questions"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="@color/surface_variant"
        android:textColor="@color/on_surface"
        app:cornerRadius="16dp"
        app:layout_constraintTop_toBottomOf="@+id/btnAddCodeChallenge"
        android:layout_marginTop="16dp"/>

    <Button
        android:id="@+id/btnManageUsers"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="👥 Manage Users"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="@color/secondary"
        android:textColor="@color/on_secondary"
        app:cornerRadius="16dp"
        app:layout_constraintTop_toBottomOf="@+id/btnManageQuestions"
        android:layout_marginTop="16dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
